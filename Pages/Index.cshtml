@page
@model IndexModel
@{
    ViewData["Title"] = "Ana Sayfa";
}


<style>
    
    body {
        background: linear-gradient(135deg, #0078D4 0%, #00bcbc 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #333;
        margin: 0;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    
    .profile-card {
        background-color: white;
        padding: 50px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        text-align: center;
        max-width: 500px;
        width: 100%;
    }

    .profile-card h1 {
        color: #0078D4;
        margin-bottom: 20px;
        font-size: 2.5rem;
    }

    .profile-card h2 {
        font-size: 1.5rem;
        margin-bottom: 10px;
    }

    .profile-card h3 {
        font-size: 1.2rem;
        color: #666;
        margin-bottom: 30px;
    }

    .badge {
        background-color: #28a745;
        color: white;
        padding: 8px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: bold;
    }

</style>
<div class="text-center">
    <h1 class="display-4"></h1>
    
    <h2>Ad Soyad: Türker Çağlar</h2>
    <h3>Öğrenci Numarası: 231002023</h3>
    
    <p>Bulut Bilişim</p>
</div>